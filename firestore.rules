rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default-deny safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Auth Helper Primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Validate IDs up to 128 characters to prevent injection/wallet exhaustion
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Validation blueprints for User Analytics Document
    function isValidUserAnalytics(data) {
      return data.userId is string 
        && data.userId.size() <= 128
        && data.userName is string
        && data.userName.size() <= 100
        && data.courses is map
        && data.overallScore is int
        && data.overallScore >= 0
        && data.overallScore <= 100
        && data.calculationsRun is int
        && data.calculationsRun >= 0
        && data.checksRun is int
        && data.checksRun >= 0;
    }

    // Validation blueprints for User Document
    function isValidUser(data) {
      return data.userId is string
        && data.userId.size() <= 128
        && data.email is string
        && data.email.size() <= 256
        && data.isPremium is bool;
    }

    // Validation blueprints for Stripe Log Document
    function isValidStripeLog(data) {
      return data.logId is string
        && data.logId.size() <= 128
        && data.userId is string
        && data.userId.size() <= 128
        && data.event is string
        && data.event.size() <= 100
        && data.status is string
        && data.status.size() <= 50
        && data.amount is string
        && data.amount.size() <= 32
        && data.description is string
        && data.description.size() <= 500;
    }

    // match rule for the userAnalytics sub-collection
    match /userAnalytics/{userId} {
      allow read: if isOwner(userId);
      
      allow create: if isOwner(userId)
        && isValidId(userId)
        && isValidUserAnalytics(incoming())
        && incoming().userId == userId;

      allow update: if isOwner(userId)
        && isValidId(userId)
        && isValidUserAnalytics(incoming())
        && incoming().userId == userId
        && incoming().userId == existing().userId;

      allow delete: if isOwner(userId);
    }

    // match rule for the users root collection
    match /users/{userId} {
      allow read: if isOwner(userId);

      allow create: if isOwner(userId)
        && isValidId(userId)
        && isValidUser(incoming())
        && incoming().userId == userId;

      allow update: if isOwner(userId)
        && isValidId(userId)
        && isValidUser(incoming())
        && incoming().userId == userId
        && incoming().userId == existing().userId;

      allow delete: if isOwner(userId);
    }

    // match rule for nested stripe logs
    match /users/{userId}/stripe_logs/{logId} {
      allow read: if isOwner(userId);

      allow create: if isOwner(userId)
        && isValidId(userId)
        && isValidId(logId)
        && isValidStripeLog(incoming())
        && incoming().userId == userId;

      allow update: if isOwner(userId)
        && isValidId(userId)
        && isValidId(logId)
        && isValidStripeLog(incoming())
        && incoming().userId == userId
        && incoming().userId == existing().userId;

      allow delete: if isOwner(userId);
    }
  }
}
