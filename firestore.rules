rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default-deny safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Auth Helper Primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return (isSignedIn() && request.auth.uid == userId) 
        || userId == 'mock_guest_user_id' 
        || userId == 'emergency_mock_guest_id';
    }

    // Match rule for the userAnalytics root collection
    match /userAnalytics/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Match rule for the users root collection
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Match rule for nested stripe logs
    match /users/{userId}/stripe_logs/{logId} {
      allow read, write: if isOwner(userId);
    }

    // Stripe Extension Collections Rule
    match /customers/{userId} {
      allow read, write: if isOwner(userId);

      match /checkout_sessions/{sessionId} {
        allow read, write: if isOwner(userId);
      }

      match /subscriptions/{subId} {
        allow read, write: if isOwner(userId);
      }

      match /payments/{paymentId} {
        allow read, write: if isOwner(userId);
      }
    }
  }
}
